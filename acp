#!/bin/bash
# ======================================================
# 武器刻寫規劃器 - 自動提交工具 (ACP for Git Bash)
# ======================================================

# [1] git add .
# 原理：將當前目錄下所有變動加入暫存區。
git add .

# [2] git commit -m "$*"
# 原理：提交變更。
# 在 Shell 腳本中，$* 代表所有傳入的參數。
# 使用引號 "$*" 確保整個訊息被視為一個字串。
git commit -m "$*"

# [3] git push
# 原理：推送到遠端倉庫。
git push
